GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
IMAGEN_MODEL=imagen-4.0-fast-generate-001
IMAGEN_REQUEST_GAP_MS=6500
IMAGE_GENERATION_MAX_ATTEMPTS=6
IMAGE_GENERATION_RETRY_BASE_MS=15000
MOCK_GENERATION=true
STORAGE_DIR=./storage
PYTHON_BIN=/usr/bin/python3
# Overlay Korean text onto generated GIFs. Default off: visuals carry the situation.
# Set to "1" or "true" to draw text (post-process labeler picks a globally
# overlap-free slot across all 16 frames or drops the label entirely).
LABEL_TEXT_ENABLED=false
